{
    "config": {
        "gc.supported_languages": ["bg", "ch", "cs", "da", "de", "el", "en", "es-mx", "es", "et", "fi", "fr", "it", "ja", "ko", "ms", "nl", "no", "pl", "pt", "ro", "ru", "sk", "sv", "th", "zh-cn"],

        "animations": {
            "symbol_animation.default": {"id": "gc.def_symbol.scale", "hide_symbol": true},
            "win_panel.levels": [
                {"id": "0", "scale": [1, 1]},
                {"id": "1", "scale": [1, 1]},
                {"id": "2", "scale": [1.2, 1.2], "pause": 1000, "delays": [2000]},
                {"id": "3", "scale": [1.44, 1.44], "pause": 2000, "delays": [2000, 2000]},
                {"id": "4", "scale": [1.44, 1.44], "pause": 2000, "delays": [2000, 2000, 2000]},
                {"id": "5", "scale": [1.44, 1.44], "pause": 3000, "delays": [2000, 2000, 2000, 2000]}
            ]
        },

        "reels.rotation.default": {"id": "default"},
        "reels.rotation.turbo": {"@P": "config/reels.rotation.default", "id": "turbo", "first_reel_duration": 200, "next_reel_stop_delay": 120},

        "features": {
            "regular": {
                "type": "reels-spin",
                "auto-spin": false,
                "reels-set": "general",
                "reels-config": "default",
                "free": false,
                "single-game-feature": false,
                "show-cp-buttons": true
            },
            "autoplay": {
                "type": "reels-spin",
                "free": false,
                "single-game-feature": false,
                "skip-outro": true
            },
            "free-spins": {
                "type": "free-spins",
                "auto-start-more-spins": true,
                "show-total-win": true,
                "include-game-win": true,
                "show-cp-buttons": false
            },
            "fsb": {
                "type": "reels-spin",
                "auto-spin": false,
                "single-game-feature": false
            },
            "waves": {
                "type": "waves",
                "supported": false,
                "auto-start": true,
                "retrigger": true,
                "cumulative-win": true,
                "spins-count": 1,
                "more-spins-count": 1,
                "restore-reels": false,
                "skip-outro": true
            }
        },

        "win_ranges.default": {
            "regular": {},
            "free-spins": 2
        }
    },

