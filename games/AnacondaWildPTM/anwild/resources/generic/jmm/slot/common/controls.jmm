			"bp.win.title.fsb": {"font": "Arial", "size": 42, "style": "bold", "color": "#ebb125"},
            "bonus.balance.title": {"font": "Arial", "color": "#ebb125", "size": 28},
            "bonus.balance.value": {"font": "Arial", "style": "bold", "color": "#fff", "size": 28},
            "line_win": {"font": "Arial", "size": 28, "style": "bold", "color": "#fff"}
        },

        "animations": {
            "button.breath": {"type": "set", "mode": "serial", "repeat": -1, "content": [
                {"type": "scale", "duration": 500, "from.x": 0.93, "from.y": 0.93, "to.x": 1, "to.y": 1, "pivot.x": "50%", "pivot.y": "50%"},
                {"type": "scale", "duration": 500, "from.x": 1, "from.y": 1, "to.x": 0.93, "to.y": 0.93, "pivot.x": "50%", "pivot.y": "50%"}
            ]},
            "winlines.disappear": {"type": "set", "mode": "serial", "content": [
                {"type": "delay", "duration": 2000},
                {"type": "opacity", "from": 1, "to": 0, "duration": 1250}
            ]},
            "gc.def_symbol_animation.opacity": {"type": "set-widget", "lookup": "symbol.image", "duration": 2000, "repeat": -1, "content": [
                {"type": "opacity", "from": 1, "to": 0, "duration": "50%"},
                {"type": "opacity", "from": 0, "to": 1, "duration": "50%"}
            ]},
            "gc.def_symbol_animation.scale": {"type": "trackable", "impatient": true, "content": [
                {"type": "set", "repeat": -1, "content": [
                    {"type": "set-props", "xform": "identity"},
                    {"type": "scale", "from.x": 1, "from.y": 1, "to.x": 1.16, "to.y": 1.16, "pivot.x": "50%", "pivot.y": "50%", "duration": 300, "interpolator": "ease.out.symbol"},
                    {"type": "scale", "from.x": 1.16, "from.y": 1.16, "to.x": 1, "to.y": 1, "pivot.x": "50%", "pivot.y": "50%", "duration": 300, "interpolator": "ease.in.symbol"},
                    {"type": "delay", "duration": 200}
                ]}
            ]},
            "gc.big_win_celebration": {"type": "sprite", "from": "0%", "to": "100%", "duration": 1000, "repeat": -1},
            "gc.anticipation": {"type": "sprite", "from": "0%", "to": "100%", "duration": 125, "repeat": -1}
        }
    },

    "ui": {
        "label.def": {"type": "label", "text-fit": [true, true], "alignment": "center"},
        "full-screen-panel": {"type": "panel", "props": {"anchor.fit": 0}},
        "blocking-panel": {"id": "blocking_panel", "@P": "ui/full-screen-panel", "visible": false},
        "interactions-panel": {"id": "interactions_panel", "@P": "ui/full-screen-panel"},

        "bc.container": {"type": "vport", "bias": "ver"},
        "bc.value": {"@P": "ui/label.def", "format": "bet.value", "pos": [28, 26], "size": [178, 32]},
        "bc.title": {"@P": "ui/label.def", "format": "bet.title", "pos": [0, 150], "size": [234, 20]},
        "fsb.title": {"@P": "ui/label.def", "format": "fsb.title"},
        "bc.btn.minus": {"type": "ibutton", "slice": "bc.btn.minus", "pos": [28, 60], "size": [84, 84]},
        "bc.btn.plus": {"type": "ibutton", "slice": "bc.btn.plus", "pos": [122, 60], "size": [84, 84]},

        "line.win": {"id": "line_win", "type": "line-win", "managed": false, "content": [
            {"id": "line_win_panel", "type": "anchor", "layout": {"relative": true}, "size": [0.815, 0.1875], "content": [
                {"id": "_container", "type": "anchor", "layout": {"relative": true}, "props": {"anchor.fit": "6.6 1.5"}, "background": "#000", "content": [
                    {"id": "text", "@P": "ui/label.def", "format": "line_win", "props": {"anchor.fit": "-3 0 -3 0"}}
                ]}
            ]}
        ]},

        "slide-switcher": {"type": "islideswitcher", "slice": "bc.slideswitcher", "knob": {"ratio": 1, "content": [
