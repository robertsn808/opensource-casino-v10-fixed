{
    "resources": {
        "animations": {
            "widget.hide": {"type": "set-widget", "content": [
                {"type": "set-props", "visible": false}
            ]},
            "opacity.0": {"type": "set-widget", "content": [
                {"type": "set-props", "opacity": 0}
            ]},
            "fade.in.with.delay": {"type": "set-widget", "content": [
                {"#ID": "delay", "type": "delay", "duration": 0},
                {"#ID": "opacity", "type": "opacity", "from": 1, "to": 0, "duration": 0}
            ]},
            "fade.out.with.delay": {"type": "set-widget", "content": [
                {"#ID": "delay", "type": "delay", "duration": 0},
                {"#ID": "opacity", "type": "opacity", "from": 0, "to": 1, "duration": 0}
            ]},
            "start.tween.with.delay": {"type": "set-widget", "content": [
                {"#ID": "delay", "type": "delay", "duration": 0},
                {"type": "tween-animation", "action": "start"}
            ]},


            "scale.prototype": {"type": "scale", "xform.before": "identity", "pivot.x": "50%", "pivot.y": "50%"},
            "sprite.prototype": {"type": "sprite", "from": 0, "to": "100%"},

            "autoplay-selector.show": {"type": "set", "content": [
                {"type": "set-props", "visible": true},
                {"type": "slide-abs", "duration": 500, "interpolator": "ease.out", "dir": "up", "mode": "show"},
                {"type": "set-props", "disabled": false}
            ]},
            "autoplay-selector.hide": {"type": "set", "content": [
                {"type": "set-props", "disabled": true},
                {"type": "slide-abs", "duration": 500, "interpolator": "ease.out", "dir": "down", "mode": "hide"},
                {"type": "set-props", "visible": false}
            ]},

            "winframe": {"type": "set", "content": [
                {"type": "sprite", "from": 0, "to": "100%", "duration": 1000},
                {"type": "set-props", "visible": false}
            ]},
            "highlight_payout": {"type": "trackable", "impatient": true, "content": [
                {"type": "set", "duration": 1000, "repeat": -1, "content": [
                    {"type": "set-widget", "lookup": "win", "content": [
                        {"type": "set-config", "config": {"format": "paytable.winnings.on"}}
                    ]},
                    {"type": "delay", "duration": "50%"},
                    {"type": "set-widget", "lookup": "win", "content": [
                        {"type": "set-config", "config": {"format": "paytable.winnings.off"}}
                    ]},
                    {"type": "delay", "duration": "50%"}
                ]}
            ], "on-end": {"type": "set", "content": [
                {"type": "set-widget", "lookup": "symbol.count", "content": [
                    {"type": "set-config", "config": {"format": "paytable.winnings.off"}}
                ]}
            ]}},
            "6oak.anim": {"type": "trackable", "mode": "parallel", "content" : [
                {"type": "set-widget", "lookup": "wrapper", "content": [
                    {"type": "delay", "duration": 100},
                    {"type": "set", "mode": "parallel", "content": [
                        {"type": "opacity", "from": 0, "to": 1, "duration": 100},
                        {"@P": "resources/animations/scale.prototype", "from.x": 0, "from.y": 0, "to.x": 1, "to.y": 1, "duration": 520, "interpolator": "anticipate.out"},
                        {"@P": "resources/animations/palmleaf.animation"}
                    ]},
                    {"type": "delay", "duration": 1840},
                    {"type": "set", "mode": "parallel", "content": [
                        {"@P": "resources/animations/scale.prototype", "from.x": 1, "from.y": 1, "to.x": 0, "to.y": 0, "duration": 520, "interpolator": "anticipate.in"}
                    ]}
                ]}
            ],
                "on-start": {"type": "set", "content": [
                    {"type": "set-widget", "lookup": "palmleaf.left", "content": [
                        {"type": "set-config", "config": {"frame.current": 0}}
                    ]},
                    {"type": "set-widget", "lookup": "palmleaf.right", "content": [
                        {"type": "set-config", "config": {"frame.current": 0}}
                    ]}
                ]},
                "on-end": {"type": "set", "content": [
                    {"type": "set-widget", "lookup": "wrapper", "content": [
                        {"type": "set-props", "opacity": 0}
                    ]}
                ]}
            },
